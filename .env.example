# Database Configuration
# For production: ensure the database exists before first boot, or add createDatabaseIfNotExist=true to the URL
DB_URL=jdbc:mysql://localhost:3306/knowly?createDatabaseIfNotExist=true
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Security
REMEMBER_ME_KEY=generate_with_openssl_rand_hex_32

# Application Profile
SPRING_PROFILES_ACTIVE=dev

# Optional: File Upload Directory (defaults to uploads/profile)
FILE_UPLOAD_DIR=uploads/profile

# Optional: Database Pool Size for Production (defaults to 10)
DB_POOL_SIZE=10

# Mail (OTP verification emails)
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Resend API (for transactional emails)
RESEND_API_KEY=your_resend_api_key_from_resend_com

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# App
APP_BASE_URL=http://localhost:8080
